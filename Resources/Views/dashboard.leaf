<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            background: #(theme.background);
            padding: 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .form {
            display: flex;
            flex-direction: column;
            gap: 10px;
            background-color: #(theme.surface);
            padding: 30px;
            width: 450px;
            max-width: 100%;
            border-radius: 20px;
        }

        h1 {
            color: #(theme.onSurface);
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .flex-column {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .flex-column > label {
            color: #(theme.onSurface);
            font-weight: 600;
            font-size: 15px;
        }

        .inputForm {
            border: 1.5px solid #(theme.outline);
            border-radius: 10px;
            height: 50px;
            display: flex;
            align-items: center;
            padding-left: 10px;
            transition: 0.2s ease-in-out;
            background-color: #(theme.surface);
        }

        .inputForm svg {
            flex-shrink: 0;
            opacity: 0.6;
        }

        .inputForm svg path {
            fill: #(theme.onSurface);
        }

        .input {
            margin-left: 10px;
            border-radius: 10px;
            border: none;
            width: 100%;
            height: 100%;
            background: transparent;
            color: #(theme.onSurface);
            font-size: 15px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        }

        .input:focus {
            outline: none;
        }

        .input::placeholder {
            color: #(theme.onSurfaceVariant);
            opacity: 0.6;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        }

        .inputForm:focus-within {
            border: 1.5px solid #(theme.primary);
        }

        .flex-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 10px;
            justify-content: space-between;
        }

        .flex-row > div {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .flex-row input[type="checkbox"] {
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

        .flex-row > div > label {
            font-size: 14px;
            color: #(theme.onSurface);
            font-weight: 400;
            cursor: pointer;
        }

        .span {
            font-size: 14px;
            color: #(theme.primary);
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
        }

        .span:hover {
            text-decoration: underline;
        }

        .button-submit {
            margin: 20px 0 10px 0;
            background-color: #(theme.primary);
            border: none;
            color: #(theme.onPrimary);
            font-size: 15px;
            font-weight: 500;
            border-radius: 10px;
            height: 50px;
            width: 100%;
            cursor: pointer;
            transition: 0.2s ease-in-out;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        }

        .button-submit:hover {
            filter: brightness(1.16);
        }

        .button-submit:active {
            filter: brightness(0.82);
        }

        .p {
            text-align: center;
            color: #(theme.onSurface);
            font-size: 14px;
            margin: 5px 0;
        }

        .btn {
            margin-top: 10px;
            width: 100%;
            height: 50px;
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: 500;
            gap: 10px;
            border: 1px solid #(theme.outline);
            background-color: #(theme.surface);
            color: #(theme.onSurface);
            cursor: pointer;
            transition: 0.2s ease-in-out;
            text-decoration: none;
            font-size: 15px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        }

        .btn:hover {
            border: 1px solid #(theme.primary);
        }

        @media (max-width: 480px) {
            .form {
                padding: 25px 20px;
            }

            h1 {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
    <form class="form" method="POST" action="#(params.logoutRoute)">
        <h1>My Profile</h1>

        <!-- Email/Phone/Username Input -->
        #if(params.email):
        <div class="flex-column">
            <label>Email</label>
        </div>
        <div class="inputForm">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" viewBox="0 0 32 32" height="20">
                <g data-name="Layer 3" id="Layer_3">
                    <path d="m30.853 13.87a15 15 0 0 0 -29.729 4.082 15.1 15.1 0 0 0 12.876 12.918 15.6 15.6 0 0 0 2.016.13 14.85 14.85 0 0 0 7.715-2.145 1 1 0 1 0 -1.031-1.711 13.007 13.007 0 1 1 5.458-6.529 2.149 2.149 0 0 1 -4.158-.759v-10.856a1 1 0 0 0 -2 0v1.726a8 8 0 1 0 .2 10.325 4.135 4.135 0 0 0 7.83.274 15.2 15.2 0 0 0 .823-7.455zm-14.853 8.13a6 6 0 1 1 6-6 6.006 6.006 0 0 1 -6 6z"></path>
                </g>
            </svg>
            <input
                placeholder="email"
                class="input"
                type="email"
                id="email"
                name="email"
                value="#(params.email)"
                required
                readonly
                autocomplete="email"
            >
        </div>
        #endif
        #if(params.phone):
        <div class="flex-column">
            <label>Phone Number</label>
        </div>
        <div class="inputForm">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" viewBox="0 0 24 24" height="20">
                <path d="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"></path>
            </svg>
            <input
                placeholder="phone number"
                class="input"
                type="tel"
                id="phone"
                name="phone"
                value="#(params.phone)"
                required
                readonly
                autocomplete="tel"
            >
        </div>
        #endif
        #if(params.username):
        <div class="flex-column">
            <label>Username</label>
        </div>
        <div class="inputForm">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" viewBox="0 0 24 24" height="20">
                <path d="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"></path>
            </svg>
            <input
                placeholder="username"
                class="input"
                type="text"
                id="username"
                name="username"
                value="#(params.username)"
                required
                readonly
                autocomplete="username"
            >
        </div>
        #endif
        
        <div class="flex-column">
            <label>User ID</label>
            <p class="p">#(params.userID)</p>
        </div>

        <button type="submit" class="button-submit">Sign Out</button>
    </form>
</body>
</html>
